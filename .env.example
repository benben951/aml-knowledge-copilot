# AML Knowledge Copilot Configuration

# LLM Backend: "openai" or "gemma" (for offline deployment)
LLM_BACKEND=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemma Configuration (when LLM_BACKEND=gemma)
GEMMA_BACKEND=ollama
GEMMA_MODEL=gemma-4-26b-a4b

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=aml_knowledge

# RAG Settings
TOP_K_RESULTS=5
MIN_SIMILARITY_SCORE=0.7

# Thinking Mode (Gemma only - shows reasoning process for compliance audit trail)
ENABLE_THINKING_MODE=true

# Logging
LOG_LEVEL=INFO
DEBUG=false